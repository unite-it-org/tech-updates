# News Aggregator Agent Configuration

# Gemini API Key (required for agent functionality)
# Get your key from https://aistudio.google.com/app/apikey
# Note: Use the OpenAI-compatible API key from Google AI Studio
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini Model (optional, defaults to gemini-2.0-flash)
# Using OpenAI-compatible endpoint: https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_MODEL=gemini-2.0-flash

# NewsAPI Key (already configured in code, but can override here)
NEWS_API_KEY=your-newsapi-key-here

# Server Configuration
HOST=0.0.0.0
PORT=8000